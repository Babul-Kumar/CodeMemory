    {
      "name": "File Indexing Scan",
      "steps": [
        "cli.py init & scan CLI commands run.",
        "scanner/file_walker yields candidate files.",
        "scanner/tree_sitter_parser extracts AST nodes.",
        "storage/repository inserts symbols into SQLite.",
